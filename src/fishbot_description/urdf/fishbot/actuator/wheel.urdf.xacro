<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" > 
<!-- 告诉系统这个urdf使用xacro这个宏语言了 -->  
<!-- 该文件会作为子文件被引入，在其他文件设置一次即可，这里无需设置name -->
    <xacro:include filename="$(find fishbot_description)/urdf/fishbot/common_inertia.xacro"/>
    <xacro:macro name = "wheel_xacro" params="wheel_name xyz">
        <link name="${wheel_name}_link">
        <!-- ${ } 是 xacro 宏的参数替换语法 -->
            <visual>
                <!-- 轮子需要沿x轴翻滚90°，转换成弧度值就是1/2Π(pai) -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <geometry>
                <!-- 圆柱体，轮子半径3.2cm，宽度4cm -->
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <material name="yellow">
                    <!-- rgba分别表示红、绿、蓝和不透明度，1.0表示不透明，0.5表示半透明 -->
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <!-- 轮子需要沿x轴翻滚90°，转换成弧度值就是1/2Π(pai) -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <geometry>
                <!-- 圆柱体，轮子半径3.2cm，宽度4cm -->
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <material name="yellow">
                    <!-- rgba分别表示红、绿、蓝和不透明度，1.0表示不透明，0.5表示半透明 -->
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </collision>
            <xacro:cylinder_inertia m="0.05" r = "0.032" h="0.04" />
        </link>

        <!-- 机器人的关节，用于组合机器人的部件 -->
        <!-- fixed是固定的，但是轮子是可转动的，所以这里使用continuous -->
        <joint name="${wheel_name}_joint" type="continuous">
            <!-- 父部件 -->
            <parent link="base_link"/>
            <!-- 子部件 -->
            <child link="${wheel_name}_link"/>
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <axis xyz="0.0 1.0 0.0"/>
        </joint>
        <gazebo reference="${wheel_name}_link">
            <!-- 切向摩擦系数 -->
            <mu1 value="20.0"/>
            <!-- 法向摩擦系数 -->
            <mu2 value="20.0"/>
            <!-- 接触刚度系数 -->
            <kp value="1000000000.0"/>
            <!-- 阻尼系数 -->
            <kd value="1.0"/>
        </gazebo>

    </xacro:macro>
</robot>